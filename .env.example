# ============================================
# Personal Accountant — Environment Variables
# ============================================

# --- Database ---
# Option A: Docker PostgreSQL (docker-compose postgres service mapped to host port 5433)
DATABASE_URL=postgres://pa_user:pa_password@localhost:5433/personal_accountant
DB_HOST=localhost
DB_PORT=5433
# Option B: Local PostgreSQL already running on the default port
# DATABASE_URL=postgres://pa_user:pa_password@localhost:5432/personal_accountant
# DB_HOST=localhost
# DB_PORT=5432
DB_NAME=personal_accountant
DB_USER=pa_user
DB_PASSWORD=pa_password

# --- MongoDB (Agenda Jobs) ---
MONGODB_URI=mongodb://admin:pa_mongo_pass@localhost:27017/agenda?authSource=admin

# --- Gotenberg PDF ---
GOTENBERG_URL=http://localhost:3002

# --- JWT Auth ---
JWT_SECRET=your-very-long-random-secret-key-here-at-least-64-chars
JWT_EXPIRES_IN=7d

# --- AES Encryption (for LHDN credentials) ---
AES_SECRET_KEY=your-32-char-aes-key-here-padded!

# --- Claude AI (OCR & Accounting AI) ---
CLAUDE_API_KEY=sk-ant-...

# --- LHDN MyInvois ---
MYINVOIS_SANDBOX_URL=https://preprod-api.myinvois.hasil.gov.my
MYINVOIS_PROD_URL=https://api.myinvois.hasil.gov.my

# --- Storage (MinIO — S3-compatible local object storage) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=pa_minio
MINIO_SECRET_KEY=pa_minio_secret
MINIO_BUCKET=pa-documents
MINIO_PUBLIC_URL=http://localhost:9000

# --- Email (nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourbusiness.com

# --- App ---
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:5173

# --- Initial Admin Password (set on first run) ---
ADMIN_PASSWORD=changeme123
